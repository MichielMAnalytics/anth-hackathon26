DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/matching
TEST_DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/matching_test
JWT_SECRET=change-me-in-prod
ANTHROPIC_API_KEY=
LOG_LEVEL=INFO

# --- Twilio SMS (optional) -------------------------------------------------
# Leave blank to keep operator sends in stub mode (DB rows only, nothing
# sent over the wire). Fill these in to actually deliver SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Trial accounts can only send to numbers verified in the Twilio console.
# Set this to your verified phone (E.164, e.g. +316...) and EVERY broadcast
# is rerouted to it — useful for demos so you can't accidentally fan out.
TWILIO_DEMO_RECIPIENT=
# Hard cap on real audience fan-out when DEMO_RECIPIENT is unset.
TWILIO_MAX_RECIPIENTS=25
# Rescue team audience — explicit phone:name list. Bypasses DEMO_RECIPIENT
# so every member actually receives the SMS. All numbers must be verified
# in the Twilio console while on a trial account.
# Format: +316...:Alice,+447...:Bob
RESCUE_TEAM_RECIPIENTS=

# Frontend gate — single shared password the operator console asks for
# before showing any data. Leave blank to disable the gate entirely.
APP_PASSWORD=
